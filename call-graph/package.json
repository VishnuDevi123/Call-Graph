{
  "name": "call-graph",
  "displayName": "Call Graph",
  "description": "Focused call graph viewer for VS Code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:call-graph.open",
    "onCommand:call-graph.focusCurrentFunction",
    "onCommand:call-graph.refreshIndex",
    "onCommand:call-graph.revealCallers",
    "onCommand:call-graph.revealCallees"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "call-graph.open",
        "title": "Open Call Graph"
      },
      {
        "command": "call-graph.refreshIndex",
        "title": "Refresh Call Graph Index"
      },
      {
        "command": "call-graph.focusCurrentFunction",
        "title": "Focus Call Graph on Current Function"
      },
      {
        "command": "call-graph.revealCallers",
        "title": "Reveal Callers"
      },
      {
        "command": "call-graph.revealCallees",
        "title": "Reveal Callees"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "call-graph.open",
          "when": "resourceLangId == python",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Call Graph",
      "properties": {
        "callGraph.maxExpansionDepth": {
          "type": "number",
          "default": 8,
          "minimum": 5,
          "maximum": 8,
          "description": "Traversal depth used by the global Max caller/callee depth controls."
        },
        "callGraph.maxGraphNodes": {
          "type": "number",
          "default": 40,
          "minimum": 5,
          "maximum": 250,
          "description": "Maximum number of nodes to render in the focused call graph."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "npm run test:unit && npm run test:vscode",
    "test:unit": "mocha --ui tdd \"out/test/analyzer/**/*.test.js\" \"out/test/webview/**/*.test.js\"",
    "test:vscode": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "mocha": "^11.7.6",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "tree-sitter-python": "^0.25.0",
    "web-tree-sitter": "^0.26.9"
  }
}
